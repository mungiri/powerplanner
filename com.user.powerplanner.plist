<?xml version="1.0" encoding="UTF-8"?>
<!--
  맥 launchd 설정: 1시간(3600초)마다 run.sh 실행.

  설치:
    1) 아래 __PROJECT_DIR__ 두 군데를 실제 경로로 바꾼다.
       (예: /Users/내이름/powerplanner)
    2) cp com.user.powerplanner.plist ~/Library/LaunchAgents/
    3) launchctl load ~/Library/LaunchAgents/com.user.powerplanner.plist
  해제:
    launchctl unload ~/Library/LaunchAgents/com.user.powerplanner.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.powerplanner</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/run.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/launchd.err.log</string>
</dict>
</plist>
