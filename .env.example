# ===== 파워플래너 (한전) 로그인 =====
KEPCO_ID=your_kepco_id
KEPCO_PW=your_kepco_password

# ===== 텔레그램 봇 =====
# @BotFather 에게서 발급받은 토큰
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# 알림 받을 채팅 ID (아래 README의 chat_id 확인 방법 참고)
TELEGRAM_CHAT_ID=123456789

# ===== 동작 옵션 =====
# 값이 바뀌었을 때만 알림 (true) / 매번 알림 (false)
NOTIFY_ON_CHANGE_ONLY=true
# 예상요금이 이 금액(원) 이상이면 경고 메시지 추가
WARN_THRESHOLD=30000
# 브라우저 창을 띄울지 (디버그용 true, 평상시 false=헤드리스)
HEADLESS=true
